{
  "version": "1.0",
  "description": "CEP Extension Development Operation Contract - Hard enforcement rules for AI agents",
  "enforcementRules": {
    "hardFail": true,
    "rejectOnViolation": true,
    "telemetryEnabled": true
  },
  "agentDeclarationSchema": {
    "type": "object",
    "required": [
      "intent",
      "phases",
      "checksRun",
      "affectedPaths",
      "invariantsCited",
      "reasoning"
    ],
    "properties": {
      "intent": {
        "type": "string",
        "description": "The operation intent being requested"
      },
      "phases": {
        "type": "array",
        "items": {
          "enum": ["analyze", "plan", "validate", "execute", "verify"]
        }
      },
      "checksRun": {
        "type": "array",
        "items": { "type": "string" }
      },
      "runtimeTestRequired": {
        "type": "boolean"
      },
      "affectedPaths": {
        "type": "array",
        "items": { "type": "string" }
      },
      "apiChecklistPassed": {
        "type": "boolean"
      },
      "invariantsCited": {
        "type": "array",
        "items": { "type": "string" }
      },
      "reasoning": {
        "type": "string"
      }
    }
  },
  "intentSchema": {
    "type": "object",
    "required": ["contractVersion", "intent", "payload"],
    "properties": {
      "contractVersion": {
        "type": "string",
        "const": "1.0"
      },
      "intent": {
        "type": "string"
      },
      "payload": {
        "type": "object"
      },
      "requestedCapabilities": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  },
  "runtimePhaseRequiredIf": [
    {
      "pathPattern": "**/*.jsx",
      "reason": "ExtendScript execution changes require AE runtime validation"
    },
    {
      "pathPattern": "**/hostscript/**/*",
      "reason": "Host script changes require runtime validation"
    },
    {
      "pathPattern": "**/CSXS/manifest.xml",
      "reason": "Manifest changes may affect extension loading"
    }
  ],
  "runtimePhaseNotRequiredIf": [
    {
      "pathPattern": "docs/**",
      "reason": "Documentation-only change"
    },
    {
      "pathPattern": "**/*.md",
      "reason": "Documentation-only change"
    },
    {
      "pathPattern": ".github/**",
      "reason": "CI/workflow change"
    },
    {
      "pathPattern": "**/*.css",
      "reason": "Style-only change"
    },
    {
      "pathPattern": "**/*.html",
      "reason": "Template-only change"
    }
  ],
  "forbiddenPatterns": {
    "es3Violations": [
      {
        "pattern": "\\bconst\\b",
        "severity": "ERROR",
        "message": "ExtendScript (ES3) does not support const",
        "fixSuggestion": "Use var"
      },
      {
        "pattern": "\\blet\\b",
        "severity": "ERROR",
        "message": "ExtendScript (ES3) does not support let",
        "fixSuggestion": "Use var"
      },
      {
        "pattern": "=>",
        "severity": "ERROR",
        "message": "ExtendScript (ES3) does not support arrow functions",
        "fixSuggestion": "Use function() syntax"
      },
      {
        "pattern": "`[^`]*\\${[^}]*}[^`]*`",
        "severity": "ERROR",
        "message": "ExtendScript (ES3) does not support template literals",
        "fixSuggestion": "Use string concatenation with +"
      },
      {
        "pattern": "\\batob\\(",
        "severity": "ERROR",
        "message": "ExtendScript (ES3) does not provide atob()",
        "fixSuggestion": "Use host-safe base64 helpers"
      },
      {
        "pattern": "\\bbtoa\\(",
        "severity": "ERROR",
        "message": "ExtendScript (ES3) does not provide btoa()",
        "fixSuggestion": "Use host-safe base64 helpers"
      },
      {
        "pattern": "\\bPromise\\b",
        "severity": "ERROR",
        "message": "ExtendScript (ES3) does not support Promises",
        "fixSuggestion": "Use callbacks or synchronous patterns"
      },
      {
        "pattern": "\\basync\\s+function",
        "severity": "ERROR",
        "message": "ExtendScript (ES3) does not support async/await",
        "fixSuggestion": "Use synchronous patterns"
      },
      {
        "pattern": "\\bclass\\b",
        "severity": "ERROR",
        "message": "ExtendScript (ES3) does not support ES6 classes",
        "fixSuggestion": "Use constructor functions and prototypes"
      },
      {
        "pattern": "\\bSymbol\\b",
        "severity": "ERROR",
        "message": "ExtendScript (ES3) does not support Symbol",
        "fixSuggestion": "Use string identifiers"
      },
      {
        "pattern": "\\bMap\\b|\\bSet\\b",
        "severity": "ERROR",
        "message": "ExtendScript (ES3) does not support Map/Set",
        "fixSuggestion": "Use plain objects and arrays"
      },
      {
        "pattern": "Object\\.assign",
        "severity": "ERROR",
        "message": "ExtendScript (ES3) does not support Object.assign",
        "fixSuggestion": "Use manual property copying"
      },
      {
        "pattern": "Array\\.from",
        "severity": "ERROR",
        "message": "ExtendScript (ES3) does not support Array.from",
        "fixSuggestion": "Use Array.prototype.slice.call for array-like objects"
      },
      {
        "pattern": "\\.includes\\(",
        "severity": "ERROR",
        "message": "ExtendScript (ES3) does not support Array/String.includes",
        "fixSuggestion": "Use indexOf !== -1"
      },
      {
        "pattern": "\\.startsWith\\(",
        "severity": "ERROR",
        "message": "ExtendScript (ES3) does not support String.startsWith",
        "fixSuggestion": "Use indexOf === 0"
      },
      {
        "pattern": "\\.endsWith\\(",
        "severity": "ERROR",
        "message": "ExtendScript (ES3) does not support String.endsWith",
        "fixSuggestion": "Use indexOf checking from end"
      }
    ],
    "securityViolations": [
      {
        "pattern": "eval\\s*\\(",
        "severity": "CRITICAL",
        "message": "eval() is forbidden - use intent-based execution only"
      },
      {
        "pattern": "Function\\s*\\(",
        "severity": "CRITICAL",
        "message": "Function constructor is forbidden"
      },
      {
        "pattern": "setInterval\\s*\\(\\s*['\"]",
        "severity": "WARNING",
        "message": "String-based setInterval is discouraged"
      },
      {
        "pattern": "setTimeout\\s*\\(\\s*['\"]",
        "severity": "WARNING",
        "message": "String-based setTimeout is discouraged"
      },
      {
        "pattern": "innerHTML\\s*=",
        "severity": "WARNING",
        "message": "Direct innerHTML assignment can be unsafe"
      }
    ]
  },
  "invariants": [
    {
      "id": "I0",
      "description": "No raw code output - only structured intents"
    },
    {
      "id": "I1",
      "description": "All file paths relative to project root"
    },
    {
      "id": "I2",
      "description": "ExtendScript must be ES3 compatible"
    },
    {
      "id": "I3",
      "description": "All changes validated before execution"
    },
    {
      "id": "I4",
      "description": "Audit trail for every operation"
    },
    {
      "id": "I5",
      "description": "Capability-based access control"
    },
    {
      "id": "I6",
      "description": "Runtime test required for execution code"
    },
    {
      "id": "I7",
      "description": "No filesystem traversal outside workspace"
    },
    {
      "id": "I8",
      "description": "Atomic commits only - rollback on failure"
    }
  ]
}
